# Platform environment template
# Copy to .env and adjust values for your environment.

# Core platform
ENVIRONMENT=development
APP_NAME=trading-platform
SCHEMA_VERSION=1.0.0
TIMEZONE_INTERNAL=UTC

# Logging overrides (optional)
# LOGGING__LEVEL=INFO
# LOGGING__FORMAT=json

# Feature flag overrides (optional — defaults are production-safe)
# FEATURE_FLAGS__SIGNAL_ONLY=true
# FEATURE_FLAGS__LIVE_TRADING_ENABLED=false

# Database (Phase 1+ — not used in Phase 0)
# DATABASE__URL=postgresql://trading:trading@localhost:5432/trading

# Redis (Phase 1+ — not used in Phase 0)
# REDIS__URL=redis://localhost:6379/0

# Legacy LLM keys (dashboard / main.py — at least one provider key required)
LLM_PROVIDER=auto
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-20b:free
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
